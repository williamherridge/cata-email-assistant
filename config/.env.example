# Local development settings for the CATA email assistant.

APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
APP_SECRET_KEY=change-me

# Lean pilot persistence
DATABASE_URL=sqlite:///data/processed/app/cata_email_assistant.db
ARTIFACT_ROOT=data/processed/artifacts

# Gmail OAuth local file paths
GOOGLE_OAUTH_CREDENTIALS_PATH=config/credentials.json
GOOGLE_OAUTH_TOKEN_PATH=config/token.json
DEFAULT_GMAIL_ADDRESS=
DEFAULT_GMAIL_DISPLAY_NAME=CATA Inbox
GMAIL_INITIAL_SYNC_DAYS=30
GMAIL_INITIAL_SYNC_MAX_RESULTS=50
TEAM_REGISTRATION_SPREADSHEET_ID=
TEAM_REGISTRATION_SHEET_NAME=RecipientList

# Local data roots
RAW_EMAIL_DATA_DIR=data/raw
PROCESSED_EMAIL_DATA_DIR=data/processed
TAXONOMY_DISCOVERY_DIR=data/analytics/taxonomy_discovery
