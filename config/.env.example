# Local development settings for the CATA email assistant.

APP_ENV=development
APP_PORT=8000

# OpenAI
OPENAI_API_KEY=

# Gmail OAuth local file paths
GOOGLE_OAUTH_CREDENTIALS_PATH=config/credentials.json
GOOGLE_OAUTH_TOKEN_PATH=config/token.json

# Local data roots
RAW_EMAIL_DATA_DIR=data/raw
PROCESSED_EMAIL_DATA_DIR=data/processed
TAXONOMY_DISCOVERY_DIR=data/analytics/taxonomy_discovery
